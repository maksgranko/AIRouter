# Переменные окружения для AI Роутера

# --- Аутентификация Панели Администратора ---
# Логин для доступа к панели администратора (/admin/dashboard)
ADMIN_USERNAME=admin
# Пароль для доступа к панели администратора. ЗАМЕНИТЕ НА НАДЕЖНЫЙ ПАРОЛЬ!
ADMIN_PASSWORD=supersecret

# --- Настройки Прокси-сервера ---
# Включает (true) или выключает (false) использование прокси-серверов.
# Если false, все запросы будут идти напрямую, игнорируя proxies.json.
# Если true, но proxies.json пуст или не найден, прокси также не будут использоваться.
# Значение по умолчанию, если переменная не установлена: true
USE_PROXIES=true

# Режим ротации прокси при ошибках (если USE_PROXIES=true):
# "once" - однократный обход списка прокси. Если все прокси в списке не сработали для текущего ключа,
#          происходит попытка смены API ключа.
# "cycle" - циклический обход списка прокси. Если все прокси в списке не сработали,
#           начинается повторный обход списка с первого прокси для того же API ключа.
# Значение по умолчанию, если переменная не установлена: once
PROXY_ROTATION_MODE=once

# --- Настройки API ключей (эти ключи больше не используются напрямую из .env, а из JSON файлов) ---
# OPENAI_API_KEY=your-openai-key-here  (УСТАРЕЛО, используйте openai_keys.json)
# GEMINI_API_KEY=your-gemini-key-here  (УСТАРЕЛО, используйте gemini_keys.json)

# --- Настройки Логирования (если будут добавлены) ---
# LOG_LEVEL=INFO # Например: DEBUG, INFO, WARNING, ERROR, CRITICAL

# --- Настройки Uvicorn (примеры, обычно передаются через CLI) ---
# HOST=0.0.0.0
# PORT=8000
# WORKERS=1
